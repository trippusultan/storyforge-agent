# StoryForge Agent - environment configuration
# Copy this file to `.env` and fill in your real keys.

# Google Gemini API key -> https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily API key -> https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Firebase (for authentication + per-user search history)
# Firebase Console -> Project settings -> Your apps -> Web app -> SDK config.
# The web API key is NOT secret; access is governed by Firestore security rules.
# Enable Email/Password under Authentication, and create a Firestore database.
FIREBASE_API_KEY=your_firebase_web_api_key_here
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
TAVILY_MAX_RESULTS=5
